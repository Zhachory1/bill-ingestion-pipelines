# Environment Configuration
# Copy this file to .env and fill in your values

# LLM API Keys (optional — users provide their own at runtime)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Database Configuration
# For local development with Docker Compose (default)
DATABASE_URL=postgresql://billchatbot:billchatbot_dev_password@postgres:5432/billchatbot

# For local development without Docker
# DATABASE_URL=postgresql://billchatbot:billchatbot_dev_password@localhost:5432/billchatbot

# For SQLite (simple local testing)
# DATABASE_URL=sqlite:///./data/bills.db

# PostgreSQL credentials (used by docker-compose)
POSTGRES_USER=billchatbot
# WARNING: Change these credentials before any non-local deployment
POSTGRES_PASSWORD=billchatbot_dev_password
POSTGRES_DB=billchatbot
POSTGRES_PORT=5432

# PgAdmin Configuration (for development)
PGADMIN_DEFAULT_EMAIL=admin@billchatbot.local
PGADMIN_DEFAULT_PASSWORD=admin

# Application Settings
LOG_LEVEL=INFO
ENVIRONMENT=development

# Retrieval Settings
DEFAULT_RETRIEVAL_STRATEGY=semantic
MAX_RESULTS=10
EMBEDDING_MODEL=all-MiniLM-L6-v2

# LLM Settings
# LLM_PROVIDER must be "anthropic" or "openai" (validated at startup)
# LLM_MODEL will use provider-specific defaults if not set:
#   - anthropic: claude-opus-4-5
#   - openai: gpt-4o
# You can override with any valid model for your chosen provider
LLM_PROVIDER=anthropic
# LLM_MODEL=                       # Leave empty for provider default
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000

# Web Server Settings
HOST=0.0.0.0
PORT=8000
RELOAD=true

# Rate Limiting (per-IP limits for expensive endpoints)
# Set RATE_LIMIT_ENABLED=false to disable for local development
RATE_LIMIT_ENABLED=true
RATE_LIMIT_SEARCH=20/minute      # Semantic search (embedding + vector query)
RATE_LIMIT_CHAT=10/minute        # Chat (LLM calls, external text fetch)
RATE_LIMIT_FULLTEXT=15/minute    # Full text fetch from govinfo.gov

# Input Validation Limits
MAX_QUERY_LENGTH=500             # Max characters in search query
MAX_MESSAGE_LENGTH=5000          # Max characters per chat message
MAX_MESSAGE_COUNT=50             # Max messages in conversation history

# ETL Settings
ETL_BATCH_SIZE=100
ETL_RATE_LIMIT_DELAY=1.0

# --- ETL Pipeline paths (used by docker compose ETL services) ---
# Absolute path on the host to the unzipped BILLSTATUS corpus
CORPUS_DIR=/path/to/congress/data/bills

# Absolute path on the host to the local unitedstates/congress git repo
REPO_PATH=/path/to/congress
