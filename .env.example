# Environment Configuration
# Copy this file to .env and fill in your values

# LLM API Keys
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Data Source API Keys (if required)
CONGRESS_GOV_API_KEY=your_congress_api_key_here
GOVTRACK_API_KEY=your_govtrack_api_key_here

# Database Configuration
# For local development with Docker Compose (default)
DATABASE_URL=postgresql://billchatbot:billchatbot_dev_password@postgres:5432/billchatbot

# For local development without Docker
# DATABASE_URL=postgresql://billchatbot:billchatbot_dev_password@localhost:5432/billchatbot

# For SQLite (simple local testing)
# DATABASE_URL=sqlite:///./data/bills.db

# PostgreSQL credentials (used by docker-compose)
POSTGRES_USER=billchatbot
POSTGRES_PASSWORD=billchatbot_dev_password
POSTGRES_DB=billchatbot
POSTGRES_PORT=5432

# PgAdmin Configuration (for development)
PGADMIN_DEFAULT_EMAIL=admin@billchatbot.local
PGADMIN_DEFAULT_PASSWORD=admin

# Application Settings
LOG_LEVEL=INFO
ENVIRONMENT=development

# Retrieval Settings
DEFAULT_RETRIEVAL_STRATEGY=semantic
MAX_RESULTS=10
EMBEDDING_MODEL=all-MiniLM-L6-v2

# LLM Settings
LLM_PROVIDER=openai
LLM_MODEL=gpt-4-turbo-preview
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000

# Web Server Settings
HOST=0.0.0.0
PORT=8000
RELOAD=true

# ETL Settings
ETL_BATCH_SIZE=100
ETL_RATE_LIMIT_DELAY=1.0

# --- ETL Pipeline paths (used by docker compose ETL services) ---
# Absolute path on the host to the unzipped BILLSTATUS corpus
CORPUS_DIR=/path/to/congress/data/bills

# Absolute path on the host to the local unitedstates/congress git repo
REPO_PATH=/path/to/congress
